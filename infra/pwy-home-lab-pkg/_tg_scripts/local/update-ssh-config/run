#!/bin/bash
# Update the local dynamic SSH config with all provisioned hosts from the
# current Ansible inventory.  Called by the local.updates Terragrunt wave
# via null_resource__run-script.
set -euo pipefail
function handle_error {
    local exit_status=$?
    echo "An error occurred on line $LINENO: $BASH_COMMAND"
    exit $exit_status
}
trap handle_error ERR

GIT_ROOT="$(git rev-parse --show-toplevel)"
. "$GIT_ROOT/set_env.sh"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
. "$_UTILITIES_DIR/bash/init.sh"

################################################################################
# Configuration
################################################################################

PKG_CONFIG="$_INFRA_DIR/pwy-home-lab-pkg/_config/pwy-home-lab-pkg.yaml"
INVENTORY_FILE="${_DYNAMIC_DIR}/ansible/inventory/hosts.yml"

# Read dynamic_config_path from pwy-home-lab-pkg.yaml; fall back to default location
DYNAMIC_CONFIG_PATH=$(python3 -c "
import yaml, os, sys
with open('$PKG_CONFIG') as f:
    cfg = yaml.safe_load(f)
path = (cfg.get('pwy-home-lab-pkg', {})
        .get('ssh_config', {})
        .get('dynamic_config_path', '~/.ssh/conf.d/dynamic_ssh_config'))
print(os.path.expanduser(path))
" 2>/dev/null)

SSH_CONFIG="$HOME/.ssh/config"

################################################################################
# Functions
################################################################################

function show_usage() {
    printf "Usage: %s <command>\n" "$0"
    cat <<EOF
    -b|--build      Regenerate inventory and write SSH config
    -t|--test       Verify dynamic SSH config file exists and has content
    -c|--clean      Remove the generated dynamic SSH config file
    -C|--clean-all  Same as --clean
    -s|--status     Show the current dynamic SSH config
    -h|--help       Show this help
EOF
    exit 1
}

if [[ $# -lt 1 ]]; then
    show_usage
fi

# Ensure ~/.ssh and ~/.ssh/config exist with correct permissions
_ensure_ssh_dir() {
    if [[ ! -d "$HOME/.ssh" ]]; then
        mkdir -p "$HOME/.ssh"
        chmod 700 "$HOME/.ssh"
        echo "Created $HOME/.ssh"
    fi
    if [[ ! -f "$SSH_CONFIG" ]]; then
        touch "$SSH_CONFIG"
        chmod 600 "$SSH_CONFIG"
        echo "Created $SSH_CONFIG"
    fi
}

# Ensure the Include directive is present in ~/.ssh/config
_ensure_include() {
    local include_line="Include $DYNAMIC_CONFIG_PATH"
    if ! grep -qF "$include_line" "$SSH_CONFIG"; then
        # Prepend — Include directives must come before any Host blocks
        local tmp
        tmp=$(mktemp)
        {
            echo "# Managed by update-ssh-config — do not remove this line"
            echo "$include_line"
            echo ""
            cat "$SSH_CONFIG"
        } > "$tmp"
        mv "$tmp" "$SSH_CONFIG"
        chmod 600 "$SSH_CONFIG"
        echo "Added '$include_line' to $SSH_CONFIG"
    else
        echo "Include already present in $SSH_CONFIG"
    fi
}

# Parse inventory YAML and write SSH Host stanzas to DYNAMIC_CONFIG_PATH
_generate_ssh_config() {
    python3 - "$INVENTORY_FILE" "$DYNAMIC_CONFIG_PATH" <<'PYEOF'
import sys, yaml, re, os
from datetime import datetime

inventory_path = sys.argv[1]
output_path = sys.argv[2]

with open(inventory_path) as f:
    inv = yaml.safe_load(f)

# Collect all unique hosts across all inventory groups
hosts = {}
def collect(node):
    if not isinstance(node, dict):
        return
    for h, vars in (node.get('hosts') or {}).items():
        if h not in hosts:
            hosts[h] = vars or {}
    for child in (node.get('children') or {}).values():
        collect(child)

collect(inv.get('all', {}))

lines = [
    "# Generated by infra/pwy-home-lab-pkg/_tg_scripts/local/update-ssh-config/run",
    f"# Last updated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
    "",
]

for hostname in sorted(hosts.keys()):
    v = hosts[hostname]
    ip = v.get('ansible_host', '')
    user = v.get('ansible_user', '')
    ssh_args = v.get('ansible_ssh_common_args', '')

    if not ip:
        continue

    lines.append(f"Host {hostname}")
    lines.append(f"    HostName {ip}")
    if user:
        lines.append(f"    User {user}")

    # Translate ansible_ssh_common_args into SSH config directives
    if ssh_args:
        jump = re.search(r'-J\s+(\S+)', ssh_args)
        if jump:
            lines.append(f"    ProxyJump {jump.group(1)}")
        if re.search(r'-o\s+StrictHostKeyChecking=no', ssh_args, re.IGNORECASE):
            lines.append("    StrictHostKeyChecking no")
        if re.search(r'-o\s+UserKnownHostsFile=/dev/null', ssh_args, re.IGNORECASE):
            lines.append("    UserKnownHostsFile /dev/null")

    lines.append("")

os.makedirs(os.path.dirname(output_path), exist_ok=True)
with open(output_path, 'w') as f:
    f.write('\n'.join(lines))
os.chmod(output_path, 0o600)
print(f"Wrote {len(hosts)} host(s) to {output_path}")
PYEOF
}

function build() {
    echo "=== Updating SSH config ==="

    echo ""
    echo "--- Regenerating Ansible inventory ---"
    "$_GENERATE_INVENTORY" --exclude-unreachable

    echo ""
    echo "--- Writing SSH config ---"
    _ensure_ssh_dir
    _ensure_include
    mkdir -p "$(dirname "$DYNAMIC_CONFIG_PATH")"
    _generate_ssh_config

    echo ""
    echo "Dynamic config : $DYNAMIC_CONFIG_PATH"
    echo "Main SSH config: $SSH_CONFIG"
    echo "=== Done ==="
}

function test_app() {
    echo "=== SSH Config test ==="
    if [[ ! -f "$DYNAMIC_CONFIG_PATH" ]]; then
        echo "FAIL: dynamic SSH config not found: $DYNAMIC_CONFIG_PATH"
        exit 1
    fi
    local host_count
    host_count=$(grep -c '^Host ' "$DYNAMIC_CONFIG_PATH" || true)
    if [[ "$host_count" -eq 0 ]]; then
        echo "FAIL: dynamic SSH config exists but has no Host entries"
        exit 1
    fi
    echo "PASS: dynamic SSH config has $host_count host(s) — $DYNAMIC_CONFIG_PATH"
}

function clean() {
    if [[ -f "$DYNAMIC_CONFIG_PATH" ]]; then
        rm "$DYNAMIC_CONFIG_PATH"
        echo "Removed $DYNAMIC_CONFIG_PATH"
    else
        echo "Nothing to clean (dynamic config not present)"
    fi
}

function show_status() {
    echo "=== SSH Config Status ==="
    echo "Dynamic config : $DYNAMIC_CONFIG_PATH"
    echo "Main SSH config: $SSH_CONFIG"
    echo ""
    if [[ -f "$DYNAMIC_CONFIG_PATH" ]]; then
        echo "--- $DYNAMIC_CONFIG_PATH ---"
        cat "$DYNAMIC_CONFIG_PATH"
    else
        echo "(dynamic config not found — run --build)"
    fi
}

################################################################################
# Argument dispatch
################################################################################
while [[ $# -gt 0 ]]; do
  case "$1" in
    -b|--build)     shift; build ;;
    -t|--test)      shift; test_app ;;
    -c|--clean)     shift; clean ;;
    -C|--clean-all) shift; clean ;;
    -s|--status)    shift; show_status ;;
    -d|--deps)      shift; echo "No additional deps required." ;;
    -h|--help)      show_usage ;;
    *)              shift ;;
  esac
done
